// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String?
  phone          String?
  address         String?
  password       String?
  emailVerified  Boolean  @default(false)
  emailToken     String?  // For email verification
  newEmail       String?  // Temporary field for pending email change
  resetToken     String?  // For password reset
  resetTokenExpiry DateTime? // Password reset token expiry
  role           String   @default("user") // "user", "admin", or "staff"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  orders         Order[]
  cartItems     CartItem[]
  wishlistItems  WishlistItem[]
  reviews        ProductReview[]
  addresses      Address[]
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName    String
  phone       String
  addressLine1 String
  addressLine2 String?
  city        String
  district    String?
  division    String
  postalCode  String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([isDefault])
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  image       String?
  isActive    Boolean  @default(true)
  products    Product[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Product {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  categoryId     String
  category       Category  @relation(fields: [categoryId], references: [id])
  price          Float     @default(0) // For backward compatibility - will be renamed to basePrice in migration
  basePrice      Float     @default(0) // Base price for products without variants
  comparePrice   Float?
  discount       Float?    @default(0)
  discountType   String?   @default("percentage") // 'percentage' | 'fixed'
  images         String?   // Default images (JSON array) - used if no variants
  stock          Int       @default(0) // Total stock - calculated from variants if they exist
  lowStockAlert  Int       @default(10)
  reorderLevel   Int       @default(5)
  reorderQty     Int       @default(20)
  isActive       Boolean   @default(true)
  isFeatured     Boolean   @default(false)
  hasVariants    Boolean   @default(false) // Indicates if product has variants
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  variants       ProductVariant[]
  orderItems     OrderItem[]
  cartItems      CartItem[]
  wishlistItems  WishlistItem[]
  reviews        ProductReview[]
  inventoryAlerts InventoryAlert[]

  @@index([categoryId])
  @@index([isFeatured])
  @@index([isActive, createdAt(sort: Desc)])
  @@index([slug])
  @@index([isActive, isFeatured])
}

model ProductVariant {
  id              String   @id @default(cuid())
  productId       String
  product         Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku             String   @unique
  name            String   // e.g., "Red - XL", "Blue - M"
  price           Float    // Variant-specific price
  comparePrice    Float?
  stock           Int      @default(0) // Variant-specific inventory
  images          String?  // JSON array of variant image URLs
  size            String?  // Size variant: S, M, L, XL, etc.
  color           String?  // Color variant: Red, Blue, Black, etc.
  material        String?  // Material variant: Cotton, Silk, etc.
  isActive        Boolean  @default(true)
  isDefault       Boolean  @default(false) // Default variant to show on product page
  lowStockAlert   Int      @default(10)
  reorderLevel    Int      @default(5)
  reorderQty      Int      @default(20)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orderItems      OrderItem[]
  cartItems       CartItem[]
  inventoryAlerts InventoryAlert[]

  @@index([productId])
  @@index([sku])
  @@index([productId, isActive])
  @@index([productId, size, color])
}

model ProductReview {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  userName    String?
  rating      Int      // 1-5 stars
  title       String?
  comment     String?
  isVerified  Boolean  @default(false) // Verified purchase
  isApproved  Boolean  @default(false) // Admin approved
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([isApproved])
}

model WishlistItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  user            User?       @relation(fields: [userId], references: [id])
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress String
  billingAddress  String?
  city            String?
  district         String?
  division         String?
  subtotal        Float
  shipping        Float       @default(0)
  tax             Float       @default(0)
  discount        Float       @default(0)
  total           Float
  status          OrderStatus      @default(PENDING)
  paymentStatus   PaymentStatus    @default(PENDING)
  paymentMethod   String?
  trackingNumber  String?
  trackingStatus  TrackingStatus?  @default(PENDING)
  estimatedDeliveryDate DateTime?
  cancelledAt     DateTime?
  cancelledBy     String?  // 'user' or 'admin'
  cancellationReason String?
  refundedAt      DateTime?
  refundedAmount  Float?
  refundMethod    String?
  refundReason    String?
  notes           String?
  orderItems      OrderItem[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([userId])
  @@index([customerEmail])
  @@index([orderNumber])
  @@index([status, createdAt(sort: Desc)])
  @@index([customerEmail, status])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id])
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  variantId   String?  // Link to variant if product has variants
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  quantity    Int
  price       Float
  productName String
  productImage String?
  variantSku  String?  // Capture SKU at time of order
  variantSize String?  // Capture size at time of order
  variantColor String? // Capture color at time of order
  variantMaterial String? // Capture material at time of order
  createdAt   DateTime @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  variantId String?  // Link to variant if product has variants
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, productId])
  @@index([variantId])
  @@unique([userId, productId])
}

model AdminLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  adminId   String
  details   String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([entity])
  @@index([createdAt])
}

model InventoryAlert {
  id          String   @id @default(cuid())
  variantId   String?  // Support variant-level alerts
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  productId   String?  // Support product-level alerts (backward compatibility)
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  alertType   AlertType @default(LOW_STOCK)
  quantity    Int
  isRead      Boolean  @default(false)
  isResolved  Boolean  @default(false)
  resolvedAt   DateTime?
  createdAt   DateTime @default(now())

  @@index([variantId])
  @@index([productId])
  @@index([isRead, isResolved])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum TrackingStatus {
  PENDING
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum AlertType {
  LOW_STOCK
  OUT_OF_STOCK
  REORDER_NEEDED
}

model Post {
  id        String   @id @default(cuid())
  title     String
  content   String?
  published Boolean  @default(false)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([authorId])
}

// Homepage content management models
model Banner {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String
  mobileImage String? // Separate image for mobile
  buttonText  String?
  buttonLink  String?
  isActive    Boolean  @default(true)
  order       Int      @default(0) // Display order
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

model Story {
  id          String   @id @default(cuid())
  title       String
  thumbnail   String
  images      String // JSON array of image URLs
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

model Reel {
  id          String   @id @default(cuid())
  title       String
  thumbnail   String
  videoUrl    String // URL or upload path
  productIds String? // JSON array of related product IDs
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

model Promotion {
  id          String   @id @default(cuid())
  title       String
  description String?
  image       String
  ctaText     String? // Call to action text
  ctaLink     String?
  type        String?  @default("banner") // 'banner', 'stickyCard', 'modal'
  isActive    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([isActive])
  @@index([type, isActive])
}

model HomepageSettings {
  id               String   @id @default(cuid())
  sectionName       String   @unique // e.g., 'banner', 'stories', 'reels', 'promotions'
  isEnabled        Boolean  @default(true)
  autoPlay         Int      @default(5000) // Auto-play timing in ms
  displayLimit     Int?     // Max items to display
  settings         String?  // JSON for additional settings
  updatedAt        DateTime @updatedAt
}
